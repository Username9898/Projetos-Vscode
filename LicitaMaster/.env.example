# ============================================
# LicitaMaster - Configuracoes
# ============================================

# === MODO ===
# DEV = desenvolvimento, PROD = producao
MODO=DEV

# === BANCO DE DADOS ===
DB_PATH=data/licitamaster.db

# === SCRAPING ===
# Intervalo entre varreduras (minutos)
INTERVALO_VARREDURA=60
# Portais para varrer (separados por virgula)
PORTAIS=COMPRASNET,PNCP,BEC,DIARIOS
# Dias para tras na busca
DIAS_BUSCA=7

# === WHATSAPP ===
# Numero do WhatsApp (com DDI, ex: 5511999999999)
WHATSAPP_NUMERO=
# Caminho do chromium para whatsapp-web.js
CHROME_PATH=

# === EMAIL (SMTP) ===
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USUARIO=
EMAIL_SENHA=

# === COMISSOES ===
# Percentual padrao de comissao (1 a 10)
COMISSAO_PADRAO=5
# Minimo para gerar oportunidade (R$)
VALOR_MINIMO_OPORTUNIDADE=5000
# Minimo para comissao (R$)
COMISSAO_MINIMA=50

# === CRIADOR DO PROJETO ===
# Nome que aparece na documentacao
CRIADOR_NOME=Usuario do Projeto
# Seus dados de contato para repasse
REPASSE_CHAVE_PIX=
REPASSE_EMAIL=