# Environment Configuration
# Copy this file to .env and adjust values

# Application
ENVIRONMENT=development
SECRET_KEY=change-me-in-production-32chars-minimum
VERSION=1.0.0

# Database
DATABASE_URL=postgresql://dentarium:dentarium2025secure@localhost:5432/dentarium_ai
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=False

# Redis
REDIS_URL=redis://:redis2025@localhost:6379/0
REDIS_CACHE_TTL=3600

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin2025
MINIO_BUCKET_NAME=dentarium-files
MINIO_SECURE=False

# JWT / Auth
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM / AI
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama2
OPENAI_API_KEY=
HUGGINGFACE_TOKEN=

# Monitoring
SENTRY_DSN=
PROMETHEUS_ENABLED=True

# Upload
MAX_UPLOAD_SIZE=104857600
ALLOWED_EXTENSIONS=.pdf,.docx,.txt,.csv,.xlsx,.xls,.json,.xml,.png,.jpg,.jpeg,.gif,.stl,.ply,.obj,.dcm,.dicom

# OCR
TESSERACT_CMD=/usr/bin/tesseract
TESSERACT_LANG=por+eng

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=
EMAILS_FROM_NAME=Dentarium AI Enterprise

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# Feature Flags
ENABLE_OCR=True
ENABLE_CAD_CAM=True
ENABLE_PREDICTIONS=True
ENABLE_WASTE_DETECTION=True
ENABLE_SELF_HEALING=True