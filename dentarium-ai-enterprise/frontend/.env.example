# Frontend Environment Configuration
# Copy this file to .env.local and adjust values

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Dentarium AI Enterprise
NEXT_PUBLIC_APP_VERSION=1.0.0

# Feature Flags
NEXT_PUBLIC_ENABLE_OCR=true
NEXT_PUBLIC_ENABLE_DASHBOARDS=true
NEXT_PUBLIC_ENABLE_SPREADSHEETS=true
NEXT_PUBLIC_ENABLE_CAD_CAM=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_WASTE_DETECTION=true

# Analytics (Optional)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=